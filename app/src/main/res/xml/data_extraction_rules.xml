<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="myowntrip.db" />
        <exclude domain="database" path="myowntrip.db-wal" />
        <exclude domain="database" path="myowntrip.db-shm" />
        <exclude domain="file" path="trips/" />
        <exclude domain="file" path="journal/" />
        <exclude domain="file" path="destination-covers/" />
    </cloud-backup>
</data-extraction-rules>